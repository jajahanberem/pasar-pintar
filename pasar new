        /* HEADER ALA E-COMMERCE PREMIUM */
        header {
            background: linear-gradient(135deg, #0a3d62 0%, #1e3799 100%);
            color: #fff; padding: 20px 15px; text-align: center;
            border-bottom-left-radius: 20px; border-bottom-right-radius: 20px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.15);
        }
        header h1 { margin: 0; font-size: 26px; font-weight: 800; letter-spacing: 0.5px; }
        header p { margin: 6px 0 0 0; opacity: 0.85; font-size: 13px; }
        
        .container { max-width: 1400px; margin: 0 auto; padding: 15px; box-sizing: border-box; }
        
        /* NAVIGASI MENU MODERN (TABS) */
        .folder-navigation {
            display: flex; gap: 10px; margin: 15px 0; overflow-x: auto; padding-bottom: 5px;
            scrollbar-width: none;
        }
        .folder-navigation::-webkit-scrollbar { display: none; }
        .folder-btn {
            flex: 1; min-width: 140px; padding: 12px 8px; background: #fff; border: 1px solid #e1e8ed; 
            border-radius: 12px; font-size: 13px; font-weight: 700; color: #747d8c; cursor: pointer; 
            text-align: center; transition: all 0.3s ease; box-shadow: var(--card-shadow);
        }
        .folder-btn.active {
            background: var(--primary); color: #fff; border-color: var(--primary);
            transform: translateY(-2px);
        }

        .folder-content { display: none; animation: fadeIn 0.4s ease; }
        .folder-content.active { display: block; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

        /* LAYOUT UTAMA MESIN KASIR */
        .kasir-layout { display: grid; grid-template-columns: 1.3fr 1.14fr; gap: 20px; }
        @media (max-width: 1200px) { .kasir-layout { grid-template-columns: 1fr; } }

        .section-title { font-size: 18px; font-weight: 800; margin-top: 0; margin-bottom: 15px; color: #0a3d62; display: flex; align-items: center; gap: 8px;}
        .card { background: #fff; padding: 20px; border-radius: 16px; box-shadow: var(--card-shadow); margin-bottom: 20px; box-sizing: border-box;}

        /* SCANNER & KATALOG BARANG */
        .search-box { 
            width: 100%; padding: 14px; border: 2px solid #e1e8ed; border-radius: 12px; 
            box-sizing: border-box; font-size: 14px; transition: all 0.3s; background: #f1f2f6;
        }
        .search-box:focus { border-color: var(--primary); background: #fff; outline: none; }
        
        .btn-kamera { 
            background: linear-gradient(135deg, #a55eea 0%, #8854d0 100%); color: white; 
            border: none; padding: 12px; border-radius: 12px; font-weight: bold; width: 100%; 
            margin-bottom: 15px; cursor: pointer; font-size: 14px; box-shadow: 0 4px 10px rgba(136, 84, 208, 0.3);
        }
        #reader, #reader-input { width: 100%; max-width: 400px; margin: 0 auto 15px auto; border-radius: 12px; overflow: hidden; display: none; border: 3px solid #8854d0;}

        /* ETALASE KATALOG GRID */
        .filter-scroll { display: flex; gap: 8px; overflow-x: auto; margin-bottom: 15px; padding-bottom: 5px; scrollbar-width: none; }
        .filter-scroll::-webkit-scrollbar { display: none; }
        .filter-badge { 
            padding: 8px 16px; background: #e1e8ed; border-radius: 20px; font-size: 12px; 
            font-weight: 700; cursor: pointer; white-space: nowrap; color: #2f3542; transition: 0.2s;
        }
        .filter-badge.active { background: var(--secondary); color: white; }

        .katalog-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 12px; max-height: 450px; overflow-y: auto; padding: 5px; }
        
        /* KARTU PRODUK */
        .product-card { 
            background: #fff; border: 1px solid #f1f2f6; border-radius: 14px; padding: 12px; 
            box-shadow: 0 2px 6px rgba(0,0,0,0.03); cursor: pointer; transition: all 0.2s ease;
            position: relative; display: flex; flex-direction: column; justify-content: space-between;
        }
        .product-card:hover { transform: scale(1.03); box-shadow: 0 6px 15px rgba(0,0,0,0.08); border-color: var(--primary); }
        .product-card .cat-tag { font-size: 10px; font-weight: 800; color: var(--primary); background: #e8f0fe; padding: 2px 6px; border-radius: 6px; align-self: flex-start; margin-bottom: 6px; }
        .product-card .p-name { font-size: 13px; font-weight: 700; color: var(--text-main); margin: 0 0 4px 0; line-height: 1.3; }
        .product-card .p-price { font-size: 14px; font-weight: 800; color: #ff4757; margin: 0 0 4px 0; }
        .product-card .p-pack-info { font-size: 11px; color: #20bf6b; font-weight: 600; margin-bottom: 6px;}
        .product-card .p-stock { font-size: 11px; color: #a4b0be; font-weight: 600; }
        .product-card .p-stock span { font-weight: 700; }
        .product-card .add-badge { position: absolute; bottom: 10px; right: 10px; background: var(--primary); color: white; width: 24px; height: 24px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 14px; }

        /* DETAIL BELANJAAN TABLE */
        .cart-table { width: 100%; border-collapse: collapse; font-size: 13px; }
        .cart-table th { text-align: left; padding: 10px; background: #f1f2f6; font-weight: 700; color: #57606f; }
        .cart-table td { padding: 12px 10px; border-bottom: 1px solid #f1f2f6; }

        /* INPUT GRUP BARU UNTUK GROSIR */
        .row-grosir-inputs { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; background: #f8f9fa; padding: 10px; border-radius: 8px; margin-bottom: 10px; border-left: 4px solid var(--primary); }

        /* PREVIEW STRUK NOTA KASIR */
        #nota-container {
            background: #fff; padding: 15px; border-radius: 8px; border: 1px dashed #2f3542; font-family: 'Courier New', Courier, monospace; color: #000; font-size: 12px;
        }
        .nota-header { text-align: center; border-bottom: 1px dashed #333; padding-bottom: 8px; margin-bottom: 8px; }
        .nota-total { border-top: 1px dashed #333; margin-top: 8px; padding-top: 6px; text-align: right; font-weight: bold; font-size: 13px;}
        .struk-row-input { margin-top: 6px; display: flex; justify-content: space-between; align-items: center; font-weight: bold; }
        .struk-input-box { width: 85px; padding: 4px; font-size: 12px; border: 1px solid #ccc; border-radius: 4px; text-align: right; }

        /* ACTION BUTTONS */
        button.action-btn { width: 100%; padding: 12px; border: none; border-radius: 12px; font-size: 14px; font-weight: bold; cursor: pointer; transition: 0.2s; margin-top: 8px; }
        .btn-success { background: linear-gradient(135deg, #10ac84 0%, #05c46b 100%); color: white; box-shadow: 0 4px 10px rgba(5, 196, 107, 0.3); }
        .btn-blue { background: linear-gradient(135deg, #2980b9 0%, #1e3799 100%); color: white; box-shadow: 0 4px 10px rgba(30, 55, 153, 0.3); }
        .btn-orange { background: linear-gradient(135deg, #ff9f43 0%, #ee5253 100%); color: white; box-shadow: 0 4px 10px rgba(238, 82, 83, 0.3); }
        .btn-secondary { background: #747d8c; color: white; }

        /* REKAP MODAL */
        .laporan-summary { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 15px; }
        .summary-box { background: #f1f2f6; padding: 15px; border-radius: 12px; font-size: 14px; font-weight: 800; border-left: 5px solid var(--primary); }

        .form-group { margin-bottom: 15px; }
        .form-group label { display: block; margin-bottom: 6px; font-weight: 700; font-size: 13px; }
        .form-group input, .form-group select { width: 100%; padding: 10px; box-sizing: border-box; border: 1px solid #ccc; border-radius: 8px; font-size: 14px; }

        .no-print { display: inline-block; }
        @media print {
            body * { visibility: hidden; }
